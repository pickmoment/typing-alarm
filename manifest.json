{
  "manifest_version": 3,
  "name": "Typing Alarm",
  "version": "1.0.0",
  "description": "Type times to set alarms with messages, repeats, and flexible formats.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Typing Alarm"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "offscreen"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
